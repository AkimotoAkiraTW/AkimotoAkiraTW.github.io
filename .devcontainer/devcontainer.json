{
  "name": "Angular 21 Portfolio Dev Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/app",

  // VS Code 在容器內要安裝的擴充功能
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "github.vscode-github-actions",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "/app/node_modules/typescript/lib"
      }
    }
  },

  // 容器啟動後，如果 node_modules 不存在則自動安裝
  "postCreateCommand": "[ -d node_modules ] || npm ci",

  // 轉發 Angular dev server 埠口
  "forwardPorts": [4200],
  "portsAttributes": {
    "4200": {
      "label": "Angular Dev Server",
      "onAutoForward": "openBrowser"
    }
  }
}
